<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detalhes do Produto - Gerenciador</title>
    <link rel="stylesheet" href="/Css/Style.css">
</head>
<body>
    <nav>
        <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/produtos">Produtos</a></li>
            <li><a href="/sobre">Sobre</a></li>
            <li><a href="/contato">Contato</a></li>
            <li style="float: right;">
                <span style="margin-right: 10px; color: white; font-weight: bold;">
                    👤 <%= session.user ? session.user.name : 'Visitante' %>
                </span>
                <a href="/logout" style="background-color: #e74c3c; padding: 8px 15px; border-radius: 5px;">Sair</a>
            </li>
        </ul>
    </nav>

<div class="container">
    <h1>Detalhes do Produto</h1>

    <div class="form-section">
        <h2><%= product.product_name %></h2>
        <div class="product-details">
            <p><strong>ID do Produto:</strong> <%= product.id %></p>
            <p><strong>Nome:</strong> <%= product.product_name %></p>
            <p><strong>Preço:</strong> R$ <%= parseFloat(product.preco).toFixed(2) %></p>
            
            <div style="margin-top: 20px;">
                <a href="/produtos/<%= product.id %>/editar" class="btn-edit">Editar</a>
                <a href="/produtos/<%= product.id %>/deletar" class="btn-delete" onclick="return confirm('Tem certeza que deseja deletar?')">Deletar</a>
                <a href="/produtos" class="btn-cancel">Voltar</a>
            </div>
        </div>
    </div>
</div>

<footer>
    <p>&copy; 2026 - Gerenciador de Produtos</p>
</footer>
</body>
</html>
