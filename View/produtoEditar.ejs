<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Produto - Gerenciador</title>
    <link rel="stylesheet" href="/Css/Style.css">
</head>
<body>
    <nav>
        <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/produtos">Produtos</a></li>
            <li><a href="/sobre">Sobre</a></li>
            <li><a href="/contato">Contato</a></li>
        </ul>
    </nav>

<div class="container">
    <h1>Editar Produto</h1>

    <div class="form-section">
        <h2>Informações do Produto</h2>
        <form action="/produtos/<%= product.id %>/editar" method="POST">
            <div class="form-group">
                <label for="product_name">Nome do Produto:</label>
                <input type="text" id="product_name" name="product_name" value="<%= product.product_name %>" required>
            </div>
            <div class="form-group">
                <label for="preco">Preço (R$):</label>
                <input type="number" id="preco" name="preco" step="0.01" value="<%= product.preco %>" required>
            </div>
            <button type="submit" class="btn-success">Salvar Alterações</button>
            <a href="/produtos" class="btn-cancel">Cancelar</a>
        </form>
    </div>
</div>

<footer>
    <p>&copy; 2026 - Gerenciador de Produtos</p>
</footer>
</body>
</html>
